# 项目环境变量模板

# 数据集路径
DOTA_DATASET_ROOT=./data/datasets/DOTA

# 训练配置
TRAINING_CONFIG=./configs/training_config.yaml
TRAINING_DEVICE=0

# NPU 配置
NPU_DEVICE_ID=0
NPU_AIPP_MODE=static

# 服务配置
SERVICE_HOST=0.0.0.0
SERVICE_PORT=50051
SERVICE_LOG_LEVEL=INFO

# 昇腾 CANN 路径 (根据实际安装修改)
ASCEND_HOME_PATH=/usr/local/Ascend/ascend-toolkit
LD_LIBRARY_PATH=${ASCEND_HOME_PATH}/runtime/lib64:${ASCEND_HOME_PATH}/driver/lib64/common
